.TRAN 50p 5e-07
.PRINT TRAN V(outp) V(outn) V(diff)
.MEASURE TRAN t1 WHEN V(diff)=0 RISE=3 TD=5e-08
.MEASURE TRAN t2 WHEN V(diff)=0 RISE=4 TD=5e-08
.STEP vctrl_val LIST 0.3 0.5 0.7 0.9 1.0 1.1 1.3 1.5

